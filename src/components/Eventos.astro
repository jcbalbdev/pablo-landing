---
import { Image } from 'astro:assets';
import logoModal from '../assets/logodelmodal.png';
// src/components/Eventos.astro
---

<section class="evento">

  <!-- Decorative blobs -->
  <div class="evento__blob evento__blob--1" aria-hidden="true"></div>
  <div class="evento__blob evento__blob--2" aria-hidden="true"></div>

  <div class="container evento__inner">

    <!-- Badge -->
    <div class="evento__badge">
      <span class="evento__badge-dot"></span>
      Taller en vivo · Cupos limitados
    </div>

    <!-- Mascot -->
    <div class="evento__mascot">
      <Image src={logoModal} alt="Pablo mascot" class="evento__mascot-img" width={80} height={80} />
    </div>

    <!-- Title -->
    <h1 class="evento__title">
      Los <span class="highlight">4 Pecados</span> de Pablo
    </h1>

    <!-- Subtitle -->
    <p class="evento__subtitle">
      Aprende los 4 errores que te están frenando<br />
      <strong>(y cómo arreglarlo en una tarde)</strong>
    </p>

    <!-- CTA — opens modal -->
    <button class="btn-primary evento__cta" id="evento-cta-btn" type="button" aria-haspopup="dialog">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
      Quiero asegurar mi lugar
      <span class="btn-arrow">→</span>
    </button>

    <!-- Trust pill -->
    <p class="evento__trust">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Cupos limitados — asegura el tuyo ahora
    </p>

    <!-- Description -->
    <div class="evento__desc-box">
      <p class="evento__desc-intro">
        No es un taller aburrido de números y gráficas. Es una conversación honesta sobre por qué algunos de nosotros gastamos como si el dinero fuera infinito, mientras otros se obsesionan tanto que dejan de vivir.
      </p>

      <p class="evento__desc-lead"><strong>Los 4 Pecados</strong> son los patrones que todos repetimos sin darnos cuenta, los que te hacen:</p>

      <ul class="evento__sins">
        <li>
          <span class="sin-icon">💸</span>
          <span>Gastar sin saber en qué se fue tu plata</span>
        </li>
        <li>
          <span class="sin-icon">😰</span>
          <span>Pensar que el dinero siempre es un problema</span>
        </li>
        <li>
          <span class="sin-icon">⏳</span>
          <span>Aplazar decisiones hasta que sea muy tarde</span>
        </li>
        <li>
          <span class="sin-icon">😔</span>
          <span>Vivir con la culpa de no "controlar" lo que ganas</span>
        </li>
      </ul>

      <p class="evento__desc-outro">
        En este taller, <strong>Rodrigo</strong> (el que creó Pablo) te muestra exactamente cuál es tu pecado, por qué lo tienes, y los pasos simples para salir de ese ciclo.
      </p>

      <p class="evento__tag">Con IA y sin estrés. ✨</p>
    </div>

  </div>
</section>

<!-- ══ MODAL ══ -->
<!-- inline style="display:none" ensures it's hidden before JS runs -->
<div
  id="evento-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="ev-modal-title"
  style="display:none; position:fixed; inset:0; z-index:9000; align-items:center; justify-content:center;"
>
  <!-- Backdrop -->
  <div
    id="evento-modal-backdrop"
    style="position:absolute; inset:0; background:rgba(20,18,50,0.6); backdrop-filter:blur(4px);"
  ></div>

  <!-- Panel -->
  <div class="ev-modal__panel">

    <!-- Header -->
    <div class="ev-modal__header">
      <div class="ev-modal__header-text">
        <p class="ev-modal__eyebrow">Reserva tu lugar</p>
        <h2 class="ev-modal__title" id="ev-modal-title">Los 4 Pecados de Pablo</h2>
      </div>
      <button class="ev-modal__close" id="evento-modal-close" aria-label="Cerrar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Form iframe -->
    <div class="ev-modal__body">
      <iframe
        id="ev-form-iframe"
        src="about:blank"
        data-src="https://62230f95.sibforms.com/serve/MUIFACX8rlxD2OOwd3Ia07boRrmY2zazazLQQMw2uMNOowqyglyxo6zUYnjDH_gRcyKmHM7Y2ehW0-WTfafz2h8FW-p3Ai7U6IMczNT9GkHmtGs7r-oN4TMXuN3QneQ9NA0M3LqWtfqmUTYNngH3d3kxLO3nCOSk-6sN35pT1v4BulXT8eoD-OAmVYqN03VWK7CGLMt7c72ZI2AVlA=="
        frameborder="0"
        scrolling="auto"
        allowfullscreen
        title="Formulario de registro al taller Los 4 Pecados de Pablo"
        class="ev-modal__iframe"
      ></iframe>
    </div>

  </div>
</div>

<style>
  /* ────────────────────────────
     EVENTO HERO SECTION
  ──────────────────────────── */
  .evento {
    background: var(--bg-hero);
    padding: 72px 0 100px;
    position: relative;
    overflow: hidden;
  }

  .evento__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .evento__blob--1 {
    width: 420px;
    height: 420px;
    background: rgba(246, 183, 43, 0.12);
    top: -100px;
    right: -80px;
  }

  .evento__blob--2 {
    width: 340px;
    height: 340px;
    background: rgba(86, 87, 143, 0.1);
    bottom: -60px;
    left: -60px;
  }

  .evento__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Badge */
  .evento__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1.5px solid rgba(43, 44, 100, 0.12);
    border-radius: var(--radius-pill);
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-body);
    letter-spacing: 0.02em;
    animation: fadeUp 0.5s 0.1s both;
    box-shadow: 0 2px 12px rgba(43, 44, 100, 0.06);
  }

  .evento__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #E04545;
    box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 3px rgba(224, 69, 69, 0.2); }
    50%       { box-shadow: 0 0 0 6px rgba(224, 69, 69, 0.08); }
  }

  /* Mascot */
  .evento__mascot {
    width: 80px;
    height: 80px;
    animation: floatMascot 3s ease-in-out infinite, fadeUp 0.5s 0.2s both;
  }

  .evento__mascot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @keyframes floatMascot {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  /* Title */
  .evento__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 52px;
    line-height: 1.08;
    color: var(--color-heading);
    animation: fadeUp 0.6s 0.25s both;
  }

  /* Subtitle */
  .evento__subtitle {
    font-size: 20px;
    line-height: 1.5;
    color: var(--color-body);
    animation: fadeUp 0.6s 0.35s both;
  }

  .evento__subtitle strong {
    color: var(--color-heading);
    font-weight: 700;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Description box */
  .evento__desc-box {
    background: white;
    border-radius: var(--radius-lg);
    padding: 32px 36px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--card-shadow);
    text-align: left;
    animation: fadeUp 0.6s 0.45s both;
  }

  .evento__desc-intro,
  .evento__desc-lead,
  .evento__desc-outro {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0;
  }

  .evento__desc-intro {
    font-style: italic;
    color: var(--color-secondary);
    border-left: 3px solid var(--color-amber);
    padding-left: 14px;
  }

  .evento__desc-lead strong,
  .evento__desc-outro strong {
    color: var(--color-heading);
  }

  /* Sins list */
  .evento__sins {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .evento__sins li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: var(--bg-hero);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    font-size: 15px;
    color: var(--color-heading);
    font-weight: 500;
    line-height: 1.4;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .evento__sins li:hover {
    transform: translateX(4px);
    box-shadow: var(--card-shadow);
  }

  .sin-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 1px;
  }

  .evento__tag {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-navy);
    margin: 4px 0 0;
    text-align: center;
  }

  /* CTA button */
  .evento__cta {
    font-size: 18px;
    padding: 20px 36px;
    gap: 10px;
    animation: fadeUp 0.6s 0.6s both;
    box-shadow: 0 6px 24px rgba(245, 166, 35, 0.35);
    border: none;
    cursor: pointer;
  }

  /* Trust pill */
  .evento__trust {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: var(--color-secondary);
    font-weight: 500;
    animation: fadeUp 0.6s 0.75s both;
  }

  /* ────────────────────────────
     MODAL
  ──────────────────────────── */
  /* Panel */
  .ev-modal__panel {
    position: relative;
    z-index: 1;
    background: white;
    border-radius: var(--radius-lg);
    width: calc(100% - 32px);
    max-width: 600px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: panelFade 0.28s cubic-bezier(0.34, 1.1, 0.64, 1) both;
    box-shadow: 0 20px 60px rgba(43, 44, 100, 0.22);
  }

  @keyframes panelFade {
    from { transform: translateY(16px) scale(0.97); opacity: 0; }
    to   { transform: translateY(0)    scale(1);    opacity: 1; }
  }

  /* Header */
  .ev-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid rgba(43, 44, 100, 0.08);
    flex-shrink: 0;
  }

  .ev-modal__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: 2px;
  }

  .ev-modal__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-heading);
    margin: 0;
  }

  .ev-modal__close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-hero);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-heading);
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .ev-modal__close:hover {
    background: #E0DCF5;
    transform: scale(1.08);
  }

  /* Body / iframe */
  .ev-modal__body {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
  }

  .ev-modal__iframe {
    width: 100%;
    min-height: 540px;
    border: none;
    display: block;
  }

  /* ────────────────────────────
     RESPONSIVE
  ──────────────────────────── */
  @media (max-width: 768px) {
    .evento {
      padding: 56px 0 80px;
    }

    .evento__title {
      font-size: 36px;
    }

    .evento__subtitle {
      font-size: 17px;
    }

    .evento__desc-box {
      padding: 24px 20px;
    }

    .evento__cta {
      font-size: 16px;
      padding: 18px 28px;
    }
  }

  @media (max-width: 390px) {
    .evento__title {
      font-size: 30px;
    }

    .evento__mascot {
      width: 64px;
      height: 64px;
    }
  }
</style>

<script is:inline>
  (function () {
    const modal    = document.getElementById('evento-modal');
    const openBtn  = document.getElementById('evento-cta-btn');
    const closeBtn = document.getElementById('evento-modal-close');
    const backdrop = document.getElementById('evento-modal-backdrop');
    const iframe   = document.getElementById('ev-form-iframe');
    let loaded     = false;

    function openModal() {
      // Use inline style so no CSS scoping issues
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      // Lazy-load the iframe only on first open
      if (!loaded) {
        iframe.src = iframe.dataset.src;
        loaded = true;
      }
    }

    function closeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.style.display === 'flex') {
        closeModal();
      }
    });
  })();
</script>
