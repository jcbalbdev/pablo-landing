---
// src/components/WaitlistModal.astro
---

<!-- Modal Overlay -->
<div
  id="waitlist-modal"
  class="modal-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Lista de espera"
>
  <div class="modal-card">
    <!-- Close button -->
    <button class="modal-close" id="modal-close-btn" aria-label="Cerrar">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Brevo form -->
    <iframe
      width="700"
      height="650"
      src="https://62230f95.sibforms.com/serve/MUIFAIkwwtJCHMucu0QYtwvSCm7FD1bvBOpSBNNNhlru0ZUvHzyjqBcCEqknml-yPkhVYgdq4fX7GUQAinAB8gMGdEaxfbWz4lW25-E-pmipkIul3LcMRNIKMY9A8E_avYXk-wXLxTMZgPEFhYaocxf7Nx7ijkLMpbri1I1UsW7ciYJ4Sp2sjmDM6mU4wN9OA05Iv1_tlwGC6jdhtQ=="
      frameborder="0"
      scrolling="auto"
      allowfullscreen
      style="display: block;margin-left: auto;margin-right: auto;max-width: 100%;"
    ></iframe>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(43, 44, 100, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .modal-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .modal-card {
    background: white;
    border-radius: 20px;
    width: 100%;
    max-width: 580px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 24px 80px rgba(43, 44, 100, 0.22);
    transform: translateY(14px) scale(0.98);
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.25s ease;
    opacity: 0;
    overflow: hidden;
  }

  .modal-overlay.is-open .modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(238, 234, 250, 0.9);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-heading);
    transition:
      background 0.15s,
      transform 0.15s;
  }

  .modal-close:hover {
    background: #e0dbf5;
    transform: scale(1.08);
  }

  .brevo-iframe {
    display: block;
    width: 100%;
    height: 700px;
    border: none;
  }

  @media (max-width: 600px) {
    .modal-card {
      border-radius: 16px;
      max-height: 92vh;
    }

    .brevo-iframe {
      height: 650px;
    }
  }
</style>

<script>
  const modal = document.getElementById("waitlist-modal");
  const closeBtn = document.getElementById("modal-close-btn");

  function openWaitlistModal() {
    modal?.classList.add("is-open");
    modal?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  }

  function closeWaitlistModal() {
    modal?.classList.remove("is-open");
    modal?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  closeBtn?.addEventListener("click", closeWaitlistModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeWaitlistModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal?.classList.contains("is-open")) {
      closeWaitlistModal();
    }
  });

  (window as any).openWaitlistModal = openWaitlistModal;
</script>
