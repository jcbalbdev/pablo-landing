---
import { Image } from "astro:assets";
import mockupImg from "../../assets/wspPabosinshadow.svg";
import { CTA, IS_LIVE } from "../../siteConfig";
// src/components/sections/Hero.astro
---

<section class="hero" id="hero">
  <div class="container hero__inner">
    <!-- ── Left content ── -->
    <div class="hero__content">
      <div class="hero__badge-wrapper">
        <div class="hero__badge">
          <span>✨</span>
          <span>Tu asistente financiero en WhatsApp</span>
        </div>
        <div class="hero__badge-deco"></div>
      </div>

      <h1 class="hero__title">
        Manejar tu dinero<br />
        nunca fue <span class="highlight">tan fácil</span>
      </h1>

      <p class="hero__desc">
        <span class="hero__deco-dot"></span>
        Conoce a <strong>Pablo</strong>, tu asistente financiero en WhatsApp que
        te ayuda a ahorrar y controlar tus gastos <strong
          >con IA y sin estrés</strong
        >.
      </p>

      <div class="hero__ctas">
        {
          IS_LIVE ? (
          <a
            href={CTA.href!}
            class="btn-primary"
            id="hero-cta-btn"
            onclick="if(typeof fbq!=='undefined')fbq('trackCustom','Ver_Planes');if(typeof ttq!=='undefined')ttq.track('ClickButton',{content_name:'Ver_Planes'});"
          >
            {CTA.label} <span class="btn-arrow">→</span>
          </a>
          ) : (
            <button
              onclick="window.openWaitlistModal();"
              class="btn-primary"
              id="hero-cta-btn"
            >
              {CTA.label} <span class="btn-arrow">→</span>
            </button>
          )
        }
        <a href="#como-funciona" class="btn-secondary">¿Cómo funciona Pablo?</a>
      </div>

      <div class="hero__proof">
        <div class="hero__emojis">
          <span>😊</span><span>🔥</span><span>💚</span><span>✨</span><span
            >🌟</span
          >
        </div>
        <p>
          Controla tus gastos&nbsp;• Cumple tus metas financieras&nbsp;• Sin
          ansiedad ni preocupaciones
        </p>
      </div>
    </div>

    <!-- ── Right: Phone mockup ── -->
    <div class="hero__phone-area">
      <div class="float-badge float-top">¡Ahorraste S/.250! 🎉</div>

      <div class="hero__mockup-container">
        <Image
          src={mockupImg}
          alt="Pablo WhatsApp Mockup"
          class="hero__mockup-img"
        />
      </div>

      <div class="float-badge float-bottom">
        Cumpliste tu presupuesto semanal ✓
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--bg-hero);
    padding: 60px 0 80px;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
  }

  /* ── Content ── */
  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }

  .hero__badge-wrapper {
    position: relative;
    padding-right: 20px;
    padding-bottom: 5px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: #eee3dc;
    border: 1px solid #efdab3;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-heading);
    width: fit-content;
    position: relative;
    z-index: 2;
  }

  .hero__badge-deco {
    position: absolute;
    top: 5px;
    left: 20px;
    width: 100%;
    height: 100%;
    border: 1px solid #efdab3;
    border-radius: 18px;
    z-index: 1;
    pointer-events: none;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 60px;
    line-height: 1.05;
    color: var(--color-heading);
  }

  .hero__desc {
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-body);
    max-width: 460px;
    position: relative;
  }

  .hero__deco-dot {
    position: absolute;
    width: 20px;
    height: 20px;
    background: #fdebb4;
    border-radius: 50%;
    left: -40px;
    top: 20px;
    opacity: 0.8;
  }

  .hero__desc strong {
    font-weight: 700;
    color: var(--color-heading);
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero__proof {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hero__emojis {
    display: flex;
    gap: -8px;
    font-size: 22px;
  }

  .hero__emojis span {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 2px 10px rgba(43, 44, 100, 0.1);
    flex-shrink: 0;
  }

  .hero__proof p {
    font-size: 13px;
    color: var(--color-secondary);
    font-weight: 500;
    line-height: 1.6;
  }

  /* ── Phone area ── */
  .hero__phone-area {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px 20px;
  }

  .hero__mockup-container {
    width: 320px;
    filter: drop-shadow(0 40px 80px rgba(43, 44, 100, 0.2));
    position: relative;
    z-index: 5;
  }

  .hero__mockup-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Floating badges */
  .float-badge {
    position: absolute;
    padding: 10px 16px;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    z-index: 10;
    white-space: nowrap;
    animation: float 3s ease-in-out infinite;
  }

  .float-top {
    top: 10px;
    right: 0;
    background: #dff6e0;
    border: 1px solid #c5e6c7;
    color: #1a6e24;
    animation-delay: 0s;
  }

  .float-bottom {
    bottom: 40px;
    left: -10px;
    background: #fbf1da;
    border: 1px solid #e8d9b8;
    color: #7a5c1a;
    animation-delay: 1.5s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero {
      padding: 80px 0 80px;
    }

    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: 27px;
    }

    .hero__title {
      font-size: 44px;
    }

    .hero__mockup-container {
      width: 280px;
    }

    #hero-cta-btn {
      height: 64px;
      min-width: auto;
      max-width: none;
      width: auto;
      padding: 20px 22px;
      border-radius: 24px;
      gap: 8px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 60px 0 50px;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero__content {
      align-items: center;
      text-align: center;
    }

    .hero__badge-wrapper {
      padding-right: 15px;
    }

    .hero__title {
      font-size: 34px;
    }

    .hero__desc {
      font-size: 16px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero__deco-dot {
      display: block;
      left: -10px;
      top: 10px;
    }

    .hero__ctas {
      justify-content: center;
      width: 100%;
    }

    .hero__ctas a,
    .hero__ctas button {
      width: 100%;
      max-width: 320px;
    }

    #hero-cta-btn {
      width: 100%;
      max-width: 320px;
    }

    .hero__proof {
      align-items: center;
    }

    .hero__emojis {
      justify-content: center;
    }

    .hero__phone-area {
      padding: 20px 0;
    }

    .hero__mockup-container {
      width: 260px;
    }

    .float-bottom {
      left: 0;
    }
  }

  @media (max-width: 390px) {
    .hero {
      padding: 48px 0 40px;
    }

    .hero__title {
      font-size: 28px;
    }

    .hero__desc {
      font-size: 15px;
    }

    .hero__mockup-container {
      width: 220px;
    }

    .float-badge {
      font-size: 11px;
      padding: 8px 12px;
    }
  }
</style>
